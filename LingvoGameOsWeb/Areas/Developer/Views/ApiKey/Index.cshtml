@model ApiKeyManagementViewModel

@{
    ViewData["Title"] = "API ключ разработчика";
}

<div class="developer-page">
    <div class="developer-page__container">
        <h1 class="developer-page__title">API для разработчиков</h1>

        <!-- Основная секция с API ключом -->
        <div class="developer-page__section" id="apiKeySection">
            <div class="developer-page__section-title">
                <i class="fas fa-key" style="margin-right: 12px;"></i>
                Ваш API ключ
            </div>

            <form id="antiForgeryForm" style="display: none;">
                @Html.AntiForgeryToken()
            </form>

            <!-- Контейнер для динамического содержимого -->
            <div id="apiKeyContent">
                @if (!Model.HasApiKey)
                {
                    <div class="api-key__empty-state">
                        <svg class="api-key__empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                        <button id="generateApiKeyBtn" class="api-key__generate-btn">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 4v16m8-8H4" />
                            </svg>
                            Создать API ключ
                        </button>
                    </div>
                }
                else
                {
                    <div class="api-key__info">
                        <div class="api-key__status @(Model.IsApiKeyActive ? "api-key__status--active" : "api-key__status--inactive")">
                            @(Model.IsApiKeyActive ? "● Активен" : "● Неактивен")
                        </div>

                        <div class="api-key__details-list">
                            @if (Model.ApiKeyId != Guid.Empty)
                            {
                                <div class="api-key__detail">
                                    <span class="api-key__detail-label">ID ключа:</span>
                                    <span class="api-key__detail-value api-key__detail-value--id">
                                        <code>@Model.ApiKeyId</code>
                                        <button class="api-key__copy-id-btn" onclick="copyToClipboard('@Model.ApiKeyId')" title="Копировать ID">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                                            </svg>
                                        </button>
                                    </span>
                                </div>
                            }

                            @if (Model.ApiKeyCreatedAt.HasValue)
                            {
                                <div class="api-key__detail">
                                    <span class="api-key__detail-label">Создан:</span>
                                    <span class="api-key__detail-value">@Model.ApiKeyCreatedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            }

                            @if (Model.ApiKeyLastUsed.HasValue)
                            {
                                <div class="api-key__detail">
                                    <span class="api-key__detail-label">Последнее использование:</span>
                                    <span class="api-key__detail-value">@Model.ApiKeyLastUsed.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="api-key__actions">
                        <button id="regenerateApiKeyBtn" class="api-key__action-btn api-key__action-btn--regenerate">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M23 4v6h-6M1 20v-6h6" />
                                <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15" />
                            </svg>
                            Сгенерировать новый
                        </button>
                        <button id="revokeApiKeyBtn" class="api-key__action-btn api-key__action-btn--revoke">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07" />
                            </svg>
                            Отозвать ключ
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Модальное окно для отображения ключа -->
        <div id="apiKeyModal" class="api-key__modal" style="display: none;">
            <div class="api-key__modal-content">
                <div class="api-key__modal-header">
                    <h3>Ваш API ключ</h3>
                    <button class="api-key__modal-close" onclick="closeApiKeyModal()">&times;</button>
                </div>
                <div class="api-key__modal-body">
                    <div class="api-key__warning">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <circle cx="12" cy="16" r="0.5" fill="currentColor" stroke="none" />
                        </svg>
                        <span>Сохраните этот ключ в безопасном месте. Он будет показан только один раз!</span>
                    </div>
                    <div class="api-key__display">
                        <code id="apiKeyValue" class="api-key__code"></code>
                        <button class="api-key__copy-btn" onclick="copyApiKey()">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                            </svg>
                            Копировать
                        </button>
                    </div>
                </div>
                <div class="api-key__modal-footer">
                    <button class="api-key__modal-btn" onclick="closeApiKeyModal()">Закрыть</button>
                </div>
            </div>
        </div>

        <!-- Секция с документацией API -->
        <div class="developer-page__section">
            <div class="developer-page__section-title">
                <i class="fas fa-book" style="margin-right: 12px;"></i>
                Документация API
            </div>

            <div class="developer-page__description">
                Используйте ваш API ключ для доступа к нашему API. Ключ необходимо передавать в заголовке <code class="api-key__code-inline">X-API-Key</code>.
                Базовый URL: <code class="api-key__code-inline">https://рудзынг.рф</code>
            </div>

            <!-- Эндпоинты API -->
            <div class="developer-page__instructions-toggle" id="endpointsToggle">
                <span>Эндпоинты API</span>
                <svg class="developer-page__toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </div>
            <div class="developer-page__instructions-content" id="endpointsContent" style="display: none;">
                <!-- GET /api/ping -->
                <div class="api-key__endpoint">
                    <div class="api-key__endpoint-method method-get">GET</div>
                    <div class="api-key__endpoint-path">/api/ping</div>
                    <div class="api-key__endpoint-desc">Проверка доступности API</div>
                </div>
                
                <!-- POST /api/account/login -->
                <div class="api-key__endpoint">
                    <div class="api-key__endpoint-method method-post">POST</div>
                    <div class="api-key__endpoint-path">/api/account/login</div>
                    <div class="api-key__endpoint-desc">Получение userId игрока для входа в игру</div>
                </div>
                <div class="api-key__endpoint-details">
                    <div class="api-key__endpoint-request">
                        <strong>Тело запроса (данные игрока):</strong>
                        <pre class="api-key__code-block-small"><code>{
    "email": "player@example.com",
    "password": "player_password"
}</code></pre>
                    </div>
                    <div class="api-key__endpoint-response">
                        <strong>Ответ:</strong>
                        <pre class="api-key__code-block-small"><code>{
    "userId": "идентификатор-игрока"
}</code></pre>
                    </div>
                </div>

                <!-- GET /api/games/my -->
                <div class="api-key__endpoint">
                    <div class="api-key__endpoint-method method-get">GET</div>
                    <div class="api-key__endpoint-path">/api/games/my</div>
                    <div class="api-key__endpoint-desc">Получить список игр разработчика</div>
                </div>

                <!-- GET /api/users/{userId}/points -->
                <div class="api-key__endpoint">
                    <div class="api-key__endpoint-method method-get">GET</div>
                    <div class="api-key__endpoint-path">/api/users/{userId}/points</div>
                    <div class="api-key__endpoint-desc">Получить количество баллов игрока</div>
                </div>
                <div class="api-key__endpoint-details">
                    <div class="api-key__endpoint-request">
                        <strong>Параметры пути:</strong>
                        <pre class="api-key__code-block-small"><code>userId - идентификатор игрока (полученный при входе)</code></pre>
                    </div>
                    <div class="api-key__endpoint-response">
                        <strong>Ответ:</strong>
                        <pre class="api-key__code-block-small"><code>// Возвращается число - количество баллов игрока
1250</code></pre>
                    </div>
                </div>

                <!-- POST /api/users/{userId}/games/{gameId}/points -->
                <div class="api-key__endpoint">
                    <div class="api-key__endpoint-method method-post">POST</div>
                    <div class="api-key__endpoint-path">/api/users/{userId}/games/{gameId}/points</div>
                    <div class="api-key__endpoint-desc">Добавить баллы игроку за игру</div>
                </div>
                <div class="api-key__endpoint-details">
                    <div class="api-key__endpoint-request">
                        <strong>Параметры пути:</strong>
                        <pre class="api-key__code-block-small"><code>userId - идентификатор игрока
gameId - идентификатор игры разработчика</code></pre>
                        <strong>Тело запроса:</strong>
                        <pre class="api-key__code-block-small"><code>{
    "amount": 100
}</code></pre>
                    </div>
                </div>
            </div>

            <!-- Примеры запросов -->
            <div class="developer-page__instructions-toggle" id="requestToggle">
                <span>Примеры запросов</span>
                <svg class="developer-page__toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </div>
            <div class="developer-page__instructions-content" id="requestContent" style="display: none;">
                <div class="developer-page__instructions-step">
                    <h4>curl</h4>
                    <pre class="api-key__code-block"><code># Проверка доступности API
curl -X GET "https://рудзынг.рф/api/ping" \
  -H "X-API-Key: YOUR_API_KEY_HERE"

# Получение userId игрока для входа в игру
curl -X POST "https://рудзынг.рф/api/account/login" \
  -H "X-API-Key: YOUR_API_KEY_HERE" \
  -H "Content-Type: application/json" \
  -d '{"email":"player@example.com","password":"player_password"}'

# Получение списка игр разработчика
curl -X GET "https://рудзынг.рф/api/games/my" \
  -H "X-API-Key: YOUR_API_KEY_HERE"

# Получение баллов игрока
curl -X GET "https://рудзынг.рф/api/users/{userId}/points" \
  -H "X-API-Key: YOUR_API_KEY_HERE"

# Добавление баллов игроку за игру
curl -X POST "https://рудзынг.рф/api/users/{userId}/games/{gameId}/points" \
  -H "X-API-Key: YOUR_API_KEY_HERE" \
  -H "Content-Type: application/json" \
  -d '{"amount":100}'</code></pre>
                </div>

                <div class="developer-page__instructions-step">
                    <h4>Python</h4>
                    <pre class="api-key__code-block"><code>import requests

API_KEY = "YOUR_API_KEY_HERE"
BASE_URL = "https://рудзынг.рф"

headers = {
    "X-API-Key": API_KEY,
    "Content-Type": "application/json"
}

# Проверка доступности API
response = requests.get(f"{BASE_URL}/api/ping", headers=headers)
print(f"API Status: {response.status_code}")

# Получение userId игрока для входа в игру
auth_data = {
    "email": "player@example.com",
    "password": "player_password"
}
response = requests.post(
    f"{BASE_URL}/api/account/login",
    headers=headers,
    json=auth_data
)
if response.status_code == 200:
    user_id = response.json().get("userId")
    print(f"Player ID: {user_id}")

# Получение списка игр разработчика
response = requests.get(f"{BASE_URL}/api/games/my", headers=headers)
if response.status_code == 200:
    games = response.json()
    print(f"Your games: {games}")

# Получение баллов игрока
user_id = "player-id-from-login"
response = requests.get(
    f"{BASE_URL}/api/users/{user_id}/points",
    headers=headers
)
if response.status_code == 200:
    points = response.json()
    print(f"Player points: {points}")

# Добавление баллов игроку за игру
game_id = 1
points_data = {"amount": 100}
response = requests.post(
    f"{BASE_URL}/api/users/{user_id}/games/{game_id}/points",
    headers=headers,
    json=points_data
)
if response.status_code == 200:
    print("Points added successfully!")</code></pre>
                </div>

                <div class="developer-page__instructions-step">
                    <h4>C#</h4>
                    <pre class="api-key__code-block"><code>using var client = new HttpClient();
client.DefaultRequestHeaders.Add("X-API-Key", "YOUR_API_KEY_HERE");

// Проверка доступности API
var response = await client.GetAsync("https://рудзынг.рф/api/ping");

// Получение userId игрока для входа в игру
var loginData = new { email = "player@example.com", password = "player_password" };
var json = JsonSerializer.Serialize(loginData);
var content = new StringContent(json, Encoding.UTF8, "application/json");
var response = await client.PostAsync("https://рудзынг.рф/api/account/login", content);

// Получение списка игр разработчика
var response = await client.GetAsync("https://рудзынг.рф/api/games/my");

// Получение баллов игрока
var response = await client.GetAsync("https://рудзынг.рф/api/users/{userId}/points");

// Добавление баллов игроку за игру
var pointsData = new { amount = 100 };
var json = JsonSerializer.Serialize(pointsData);
var content = new StringContent(json, Encoding.UTF8, "application/json");
var response = await client.PostAsync("https://рудзынг.рф/api/users/{userId}/games/{gameId}/points", content);</code></pre>
                </div>

                <div class="developer-page__instructions-step">
                    <h4>JavaScript</h4>
                    <pre class="api-key__code-block"><code>const API_KEY = "YOUR_API_KEY_HERE";
const BASE_URL = "https://рудзынг.рф";

// Проверка доступности API
fetch(`${BASE_URL}/api/ping`, {
    headers: { "X-API-Key": API_KEY }
})
.then(response => response.json())
.then(data => console.log(data));

// Получение userId игрока для входа в игру
fetch(`${BASE_URL}/api/account/login`, {
    method: "POST",
    headers: {
        "X-API-Key": API_KEY,
        "Content-Type": "application/json"
    },
    body: JSON.stringify({
        email: "player@example.com",
        password: "player_password"
    })
})
.then(response => response.json())
.then(data => console.log("Player ID:", data.userId));

// Получение списка игр разработчика
fetch(`${BASE_URL}/api/games/my`, {
    headers: { "X-API-Key": API_KEY }
})
.then(response => response.json())
.then(data => console.log("Your games:", data));

// Получение баллов игрока
const userId = "player-id-from-login";
fetch(`${BASE_URL}/api/users/${userId}/points`, {
    headers: { "X-API-Key": API_KEY }
})
.then(response => response.json())
.then(points => console.log("Player points:", points));

// Добавление баллов игроку за игру
const gameId = 1;
fetch(`${BASE_URL}/api/users/${userId}/games/${gameId}/points`, {
    method: "POST",
    headers: {
        "X-API-Key": API_KEY,
        "Content-Type": "application/json"
    },
    body: JSON.stringify({ amount: 100 })
})
.then(response => {
    if (response.ok) console.log("Points added successfully!");
});</code></pre>
                </div>
            </div>
        </div>

        <!-- Секция с ограничениями -->
        <div class="developer-page__section">
            <div class="developer-page__section-title">
                <i class="fas fa-chart-line" style="margin-right: 12px;"></i>
                Лимиты и ограничения
            </div>
            <div class="developer-page__description">
                <ul class="api-key__limits-list">
                    <li><strong>1000</strong> запросов в день</li>
                    <li><strong>10</strong> запросов в секунду</li>
                    <li>Размер ответа до <strong>1MB</strong></li>
                    <li>Поддержка <strong>JSON</strong> формата</li>
                    <li>Ключи <strong>бессрочные</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    /* Все стили остаются без изменений */
    .api-key__empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
        text-align: center;
    }

    .api-key__empty-icon {
        width: 80px;
        height: 80px;
        color: var(--border-outline-dark);
        margin-bottom: 24px;
    }

    .api-key__generate-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        background: var(--accent-2);
        color: var(--text-light);
        border: none;
        border-radius: 73px;
        font-size: 16px;
        font-weight: 600;
        font-family: "Axiforma", sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .api-key__generate-btn:hover {
        background: var(--accent-1);
        transform: translateY(-2px);
    }

    .api-key__info {
        background: var(--bg-light);
        border-radius: 10px 50px;
        padding: 20px 24px;
        margin-bottom: 24px;
    }

    .api-key__status {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 16px;
    }

    .api-key__status--active {
        background: rgba(81, 213, 70, 0.15);
        color: var(--success-color);
    }

    .api-key__status--inactive {
        background: rgba(213, 70, 70, 0.15);
        color: var(--error-color);
    }

    .api-key__details-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .api-key__detail {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 8px 0;
        border-bottom: 1px solid var(--border-light);
    }

    .api-key__detail:last-child {
        border-bottom: none;
    }

    .api-key__detail-label {
        color: var(--text-muted);
        font-size: 14px;
        min-width: 160px;
    }

    .api-key__detail-value {
        color: var(--text-primary);
        font-weight: 500;
        font-size: 14px;
    }

    .api-key__detail-value--id {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .api-key__detail-value--id code {
        background: var(--bg-light);
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 13px;
    }

    .api-key__copy-id-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        transition: background 0.3s ease;
    }

    .api-key__copy-id-btn:hover {
        background: var(--border-light);
    }

    .api-key__copy-id-btn svg {
        stroke: var(--text-muted);
    }

    .api-key__copy-id-btn:hover svg {
        stroke: var(--accent-2);
    }

    .api-key__actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .api-key__action-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: 73px;
        font-size: 14px;
        font-weight: 500;
        font-family: "Axiforma", sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
    }

    .api-key__action-btn--regenerate {
        background: rgba(91, 127, 217, 0.15);
        color: var(--accent-3);
    }

    .api-key__action-btn--regenerate:hover {
        background: var(--accent-3);
        color: var(--text-light);
    }

    .api-key__action-btn--revoke {
        background: rgba(213, 70, 70, 0.15);
        color: var(--error-color);
    }

    .api-key__action-btn--revoke:hover {
        background: var(--error-color);
        color: var(--text-light);
    }

    .api-key__modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .api-key__modal-content {
        background: var(--bg-white);
        border-radius: 10px 70px;
        max-width: 500px;
        width: 90%;
        animation: modalSlideIn 0.3s ease;
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .api-key__modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 24px;
        border-bottom: 1px solid var(--border-light);
    }

    .api-key__modal-header h3 {
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .api-key__modal-close {
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        color: var(--text-muted);
        transition: color 0.3s ease;
    }

    .api-key__modal-close:hover {
        color: var(--error-color);
    }

    .api-key__modal-body {
        padding: 24px;
    }

    .api-key__warning {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(213, 70, 70, 0.1);
        padding: 12px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        color: var(--error-color);
        font-size: 13px;
    }

    .api-key__display {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--bg-light);
        border-radius: 73px;
        padding: 12px 20px;
    }

    .api-key__code {
        flex: 1;
        font-family: monospace;
        font-size: 14px;
        color: var(--text-primary);
        word-break: break-all;
    }

    .api-key__copy-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: var(--accent-2);
        color: var(--text-light);
        border: none;
        border-radius: 73px;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.3s ease;
    }

    .api-key__copy-btn:hover {
        background: var(--accent-1);
    }

    .api-key__modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border-light);
        display: flex;
        justify-content: flex-end;
    }

    .api-key__modal-btn {
        padding: 10px 24px;
        background: var(--bg-light);
        color: var(--text-primary);
        border: 1px solid var(--border-light);
        border-radius: 73px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .api-key__modal-btn:hover {
        background: var(--border-light);
    }

    .api-key__code-inline {
        background: var(--bg-light);
        padding: 2px 6px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 13px;
        color: var(--accent-2);
    }

    .api-key__code-block {
        background: #1a1a2e;
        color: #00ff88;
        padding: 16px;
        border-radius: 10px;
        overflow-x: auto;
        font-family: monospace;
        font-size: 13px;
        margin-top: 10px;
    }

    .api-key__code-block code {
        color: #00ff88;
    }

    .api-key__code-block-small {
        background: #1a1a2e;
        color: #00ff88;
        padding: 12px;
        border-radius: 8px;
        overflow-x: auto;
        font-family: monospace;
        font-size: 12px;
        margin: 8px 0;
    }

    .api-key__endpoint {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-light);
    }

    .api-key__endpoint:last-child {
        border-bottom: none;
    }

    .api-key__endpoint-details {
        margin-left: 76px;
        margin-bottom: 16px;
        padding: 12px;
        background: var(--bg-light);
        border-radius: 10px;
    }

    .api-key__endpoint-request,
    .api-key__endpoint-response {
        margin-bottom: 12px;
    }

    .api-key__endpoint-request strong,
    .api-key__endpoint-response strong {
        display: block;
        margin-bottom: 8px;
        color: var(--text-primary);
    }

    .api-key__endpoint-method {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        min-width: 60px;
        text-align: center;
    }

    .method-get {
        background: rgba(81, 213, 70, 0.15);
        color: var(--success-color);
    }

    .method-post {
        background: rgba(63, 105, 210, 0.15);
        color: var(--accent-2);
    }

    .api-key__endpoint-path {
        font-family: monospace;
        font-size: 14px;
        color: var(--text-primary);
        flex: 1;
    }

    .api-key__endpoint-desc {
        font-size: 13px;
        color: var(--text-muted);
    }

    .api-key__limits-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .api-key__limits-list li {
        padding: 10px 0;
        border-bottom: 1px solid var(--border-light);
        color: var(--text-body);
    }

    .api-key__limits-list li:last-child {
        border-bottom: none;
    }

    .api-key__limits-list li strong {
        color: var(--accent-2);
        font-size: 18px;
        margin-right: 8px;
    }

    @@media (max-width: 768px) {
        .api-key__actions {
            flex-direction: column;
        }

        .api-key__action-btn {
            justify-content: center;
        }

        .api-key__endpoint {
            flex-wrap: wrap;
        }

        .api-key__endpoint-desc {
            width: 100%;
            margin-left: 76px;
        }

        .api-key__endpoint-details {
            margin-left: 0;
        }
        
        .api-key__detail {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
        }
        
        .api-key__detail-label {
            min-width: auto;
        }
    }
</style>

<script type="module">
    let currentApiKey = '';

    const getToken = () => document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    window.copyToClipboard = function(text) {
        navigator.clipboard.writeText(text).then(() => {
            const btn = event?.target?.closest('.api-key__copy-id-btn');
            if (btn) {
                const originalTitle = btn.getAttribute('title');
                btn.setAttribute('title', 'Скопировано!');
                setTimeout(() => {
                    btn.setAttribute('title', originalTitle);
                }, 1500);
            } else {
                alert('ID ключа скопирован');
            }
        }).catch(() => {
            alert('Не удалось скопировать ID');
        });
    }

    function updateUIAfterCreate(apiKeyData) {
        const container = document.getElementById('apiKeyContent');
        const now = new Date().toLocaleString('ru-RU');
        
        const html = `
            <div class="api-key__info">
                <div class="api-key__status api-key__status--active">
                    ● Активен
                </div>
                <div class="api-key__details-list">
                    <div class="api-key__detail">
                        <span class="api-key__detail-label">ID ключа:</span>
                        <span class="api-key__detail-value api-key__detail-value--id">
                            <code>${apiKeyData.apiKeyId || ''}</code>
                            <button class="api-key__copy-id-btn" onclick="copyToClipboard('${apiKeyData.apiKeyId || ''}')" title="Копировать ID">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                                    <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                                </svg>
                            </button>
                        </span>
                    </div>
                    <div class="api-key__detail">
                        <span class="api-key__detail-label">Создан:</span>
                        <span class="api-key__detail-value">${now}</span>
                    </div>
                </div>
            </div>
            <div class="api-key__actions">
                <button id="regenerateApiKeyBtn" class="api-key__action-btn api-key__action-btn--regenerate">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M23 4v6h-6M1 20v-6h6"/>
                        <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                    </svg>
                    Сгенерировать новый
                </button>
                <button id="revokeApiKeyBtn" class="api-key__action-btn api-key__action-btn--revoke">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                    </svg>
                    Отозвать ключ
                </button>
            </div>
        `;

        container.innerHTML = html;
        attachEventHandlers();
    }

    function updateUIAfterRevoke() {
        const container = document.getElementById('apiKeyContent');

        const html = `
            <div class="api-key__empty-state">
                <svg class="api-key__empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                <button id="generateApiKeyBtn" class="api-key__generate-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 4v16m8-8H4"/>
                    </svg>
                    Создать API ключ
                </button>
            </div>
        `;

        container.innerHTML = html;
        attachEventHandlers();
    }

    function attachEventHandlers() {
        document.getElementById('generateApiKeyBtn')?.addEventListener('click', generateApiKey);
        document.getElementById('regenerateApiKeyBtn')?.addEventListener('click', regenerateApiKey);
        document.getElementById('revokeApiKeyBtn')?.addEventListener('click', revokeApiKey);
    }

    async function generateApiKey() {
        try {
            const response = await fetch('/Developer/ApiKey/Generate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                }
            });

            const data = await response.json();

            if (response.ok) {
                currentApiKey = data.apiKey;
                document.getElementById('apiKeyValue').textContent = currentApiKey;
                openApiKeyModal();
                updateUIAfterCreate(data);
            } else {
                alert(data.error || 'Ошибка при создании API ключа');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Ошибка при создании API ключа');
        }
    }

    async function regenerateApiKey() {
        if (confirm('Внимание! При генерации нового ключа старый ключ перестанет работать. Продолжить?')) {
            try {
                const response = await fetch('/Developer/ApiKey/Regenerate', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getToken()
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    currentApiKey = data.apiKey;
                    document.getElementById('apiKeyValue').textContent = currentApiKey;
                    openApiKeyModal();
                    updateUIAfterCreate(data);
                } else {
                    alert(data.error || 'Ошибка при регенерации ключа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при регенерации ключа');
            }
        }
    }

    async function revokeApiKey() {
        if (confirm('Внимание! После отзыва ключа он перестанет работать. Продолжить?')) {
            try {
                const response = await fetch('/Developer/ApiKey/Revoke', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getToken()
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    alert('API ключ успешно отозван');
                    updateUIAfterRevoke();
                } else {
                    alert(data.error || 'Ошибка при отзыве ключа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при отзыве ключа');
            }
        }
    }

    function openApiKeyModal() {
        const modal = document.getElementById('apiKeyModal');
        modal.style.display = 'flex';
    }

    window.closeApiKeyModal = function() {
        const modal = document.getElementById('apiKeyModal');
        modal.style.display = 'none';
    }

    window.copyApiKey = function() {
        const apiKeyValue = document.getElementById('apiKeyValue').textContent;
        navigator.clipboard.writeText(apiKeyValue).then(() => {
            alert('API ключ скопирован в буфер обмена');
        }).catch(() => {
            alert('Не удалось скопировать ключ');
        });
    }

    const requestToggle = document.getElementById('requestToggle');
    const requestContent = document.getElementById('requestContent');
    const endpointsToggle = document.getElementById('endpointsToggle');
    const endpointsContent = document.getElementById('endpointsContent');

    if (requestToggle && requestContent) {
        requestToggle.addEventListener('click', () => {
            const isVisible = requestContent.style.display === 'block';
            requestContent.style.display = isVisible ? 'none' : 'block';
            requestToggle.setAttribute('aria-expanded', !isVisible);
        });
    }

    if (endpointsToggle && endpointsContent) {
        endpointsToggle.addEventListener('click', () => {
            const isVisible = endpointsContent.style.display === 'block';
            endpointsContent.style.display = isVisible ? 'none' : 'block';
            endpointsToggle.setAttribute('aria-expanded', !isVisible);
        });
    }

    window.onclick = function(event) {
        const modal = document.getElementById('apiKeyModal');
        if (event.target === modal) {
            closeApiKeyModal();
        }
    }

    attachEventHandlers();
</script>