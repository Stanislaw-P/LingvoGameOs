@model ApiKeyManagementViewModel

<div class="api-key__info">
    <div class="api-key__status @(Model.IsApiKeyActive ? "api-key__status--active" : "api-key__status--inactive")">
        @(Model.IsApiKeyActive ? "● Активен" : "● Неактивен")
    </div>

    @if (Model.ApiKeyCreatedAt.HasValue)
    {
        <div class="api-key__detail">
            <span class="api-key__detail-label">Создан:</span>
            <span class="api-key__detail-value">@Model.ApiKeyCreatedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
    }

    @if (Model.ApiKeyLastUsed.HasValue)
    {
        <div class="api-key__detail">
            <span class="api-key__detail-label">Последнее использование:</span>
            <span class="api-key__detail-value">@Model.ApiKeyLastUsed.Value.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
    }
</div>

<div class="api-key__actions">
    <button id="showApiKeyBtn" class="api-key__action-btn api-key__action-btn--show">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
            <circle cx="12" cy="12" r="3" />
        </svg>
        Показать ключ
    </button>
    <button id="regenerateApiKeyBtn" class="api-key__action-btn api-key__action-btn--regenerate">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M23 4v6h-6M1 20v-6h6" />
            <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15" />
        </svg>
        Сгенерировать новый
    </button>
    <button id="revokeApiKeyBtn" class="api-key__action-btn api-key__action-btn--revoke">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="4.93" y1="4.93" x2="19.07" y2="19.07" />
        </svg>
        Отозвать ключ
    </button>
</div>