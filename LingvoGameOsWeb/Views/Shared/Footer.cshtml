<footer class="border-top footer text-muted">
    <div class="footer__container _container">
        <div class="footer__content">
            <!-- Логотип и описание -->
            <div class="footer__brand">
                <a asp-controller="Home" asp-action="Index" class="footer__logo-link">
                    <img src="/img/logo/logo_footer.svg" alt="LingvoGameOs Logo" class="footer__logo" />
                </a>
                <p class="footer__description">
                    Открой окно в мир родного языка
                </p>

                <!-- БЛОК СО СТАТИСТИКОЙ -->
                @await Component.InvokeAsync("FooterStatistics")
            </div>

            <!-- Команда разработчиков -->
            <div class="footer__team">
                <h3 class="footer__section-title">Наша команда</h3>
                <div class="footer__team-grid">
                    <!-- сенсей и остальные участники команды (без изменений) -->
                    <div class="footer__team-member footer__team-member--sensei">
                        <div class="footer__member-info">
                            <span class="footer__member-role">Руководитель проекта</span>
                            <a href="https://vk.com/makar_md" target="_blank" rel="noopener" class="footer__member-name">
                                Макаренко М.Д.
                            </a>
                        </div>
                    </div>

                    <div class="footer__team-member">
                        <div class="footer__member-info">
                            <span class="footer__member-role">Дизайн и фронтенд</span>
                            <a href="https://vk.com/id674366222" target="_blank" rel="noopener" class="footer__member-name">
                                Бекоева Илона
                            </a>
                        </div>
                    </div>

                    <div class="footer__team-member">
                        <div class="footer__member-info">
                            <span class="footer__member-role">Разработчик</span>
                            <a href="https://vk.com/maieha" target="_blank" rel="noopener" class="footer__member-name">
                                Персаев Станислав
                            </a>
                        </div>
                    </div>

                    <div class="footer__team-member">
                        <div class="footer__member-info">
                            <span class="footer__member-role">Разработчик</span>
                            <a href="https://vk.com/ddkhugaev" target="_blank" rel="noopener" class="footer__member-name">
                                Хугаев Давид
                            </a>
                        </div>
                    </div>

                    <div class="footer__team-member">
                        <div class="footer__member-info">
                            <span class="footer__member-role">Разработчик</span>
                            <a href="https://vk.com/istiik" target="_blank" rel="noopener" class="footer__member-name">
                                Даурова Сюзанна
                            </a>
                        </div>
                    </div>

                    <div class="footer__team-member">
                        <div class="footer__member-info">
                            <span class="footer__member-role">Разработчик</span>
                            <a href="https://vk.com/amletixq" target="_blank" rel="noopener" class="footer__member-name">
                                Назаров Амридин
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Нижняя часть футера -->
        <div class="footer__bottom">
            <div class="footer__copyright">
                <p>&copy; 2026 Рудзынг. Северо-Осетинский государственный университет</p>
            </div>
        </div>
    </div>
</footer>